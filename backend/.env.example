APP_NAME=Barbearia SaaS API
APP_VERSION=0.1.0
DEBUG=true
DATABASE_URL=postgresql+asyncpg://barbearia:barbearia@localhost:5432/barbearia
REDIS_URL=redis://localhost:6379/0
CORS_ORIGINS=http://localhost:3000

JWT_SECRET_KEY=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET_KEY=change-me-refresh-secret-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

UPLOAD_DIR=uploads
MEDIA_URL_PREFIX=/uploads
MAX_UPLOAD_SIZE_BYTES=5242880

ADMIN_EMAIL=admin@barbearia.com
ADMIN_PASSWORD=change-me-admin-password
ADMIN_NAME=Administrador
